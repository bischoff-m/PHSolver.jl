{
    "type": "object",
    "properties": {
        "network": {
            "$ref": "#/$defs/Main.PHSolver.NetworkConfig"
        },
        "simulation": {
            "$ref": "#/$defs/Main.PHSolver.SimulationConfig"
        }
    },
    "required": [
        "network",
        "simulation"
    ],
    "$defs": {
        "Main.PHSolver.Component": {
            "type": "object",
            "properties": {
                "id": {
                    "type": "string"
                },
                "dissipation": {
                    "type": "number"
                },
                "mass": {
                    "type": "number"
                },
                "x0": {
                    "type": "number"
                }
            },
            "required": [
                "id"
            ]
        },
        "Main.PHSolver.SystemPort": {
            "type": "object",
            "properties": {
                "system": {
                    "type": "string"
                },
                "port": {
                    "type": "string"
                }
            },
            "required": [
                "system",
                "port"
            ]
        },
        "Main.PHSolver.ComponentSystem": {
            "type": "object",
            "properties": {
                "id": {
                    "type": "string"
                },
                "components": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/Main.PHSolver.Component"
                    }
                },
                "connections": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/Main.PHSolver.ComponentConnection"
                    }
                },
                "ports": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "string"
                    }
                }
            },
            "required": [
                "id",
                "components",
                "connections"
            ]
        },
        "Main.PHSolver.NetworkConfig": {
            "type": "object",
            "properties": {
                "name": {
                    "type": "string"
                },
                "systems": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/Main.PHSolver.ComponentSystem"
                    }
                },
                "connections": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/Main.PHSolver.NetworkConnection"
                    }
                },
                "ports": {
                    "type": "object",
                    "additionalProperties": {
                        "$ref": "#/$defs/Main.PHSolver.SystemPort"
                    }
                }
            },
            "required": [
                "name",
                "systems"
            ]
        },
        "Main.PHSolver.SimulationConfig": {
            "type": "object",
            "properties": {
                "time_span": {
                    "type": "array",
                    "items": {
                        "type": "number"
                    }
                },
                "solver": {
                    "type": "string"
                },
                "timestep": {
                    "type": "number"
                }
            },
            "required": [
                "time_span"
            ]
        },
        "Main.PHSolver.NetworkConnection": {
            "type": "object",
            "properties": {
                "from": {
                    "$ref": "#/$defs/Main.PHSolver.SystemPort"
                },
                "to": {
                    "$ref": "#/$defs/Main.PHSolver.SystemPort"
                },
                "weight": {
                    "type": "number"
                }
            },
            "required": [
                "from",
                "to"
            ]
        },
        "Main.PHSolver.ComponentConnection": {
            "type": "object",
            "properties": {
                "from": {
                    "type": "string"
                },
                "to": {
                    "type": "string"
                },
                "weight": {
                    "type": "number"
                }
            },
            "required": [
                "from",
                "to"
            ]
        }
    }
}